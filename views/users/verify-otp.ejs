<% layout("/layouts/boilerplate") %>

<div class="auth-container">
    <h2 class="auth-title">Verify OTP</h2>
    <p style="text-align: center; color: var(--text-color); margin-bottom: 2rem;">
        Enter the 6-digit code sent to your email.
    </p>

    <form action="/verify-otp" method="POST" class="auth-form needs-validation" novalidate>
        <div class="mb-4 text-center">
            <label for="otp" class="form-label visually-hidden">One Time Password</label>
            <input type="text" 
                   id="otp" 
                   name="otp" 
                   class="form-control text-center" 
                   required 
                   maxlength="6" 
                   minlength="6" 
                   placeholder="******"
                   style="font-size: 1.5rem; letter-spacing: 0.5rem; max-width: 200px; margin: 0 auto; background-color: var(--surface-color); color: var(--text-color); border: 1px solid var(--border-color);">
            <div class="invalid-feedback">
                Please provide the valid 6-digit OTP.
            </div>
        </div>

        <button class="auth-btn w-100">Verify</button>
    </form>
    
    <div style="text-align: center; margin-top: 1.5rem;">
        <small style="color: var(--text-color);">Didn't receive the code? Please check your spam folder.</small>
    </div>
</div>