<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <h1 class="col-8 offset-2">Verify OTP</h1>
    <div class="col-8 offset-2">
        <form action="/verify-otp" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="otp" class="form-label">Enter OTP sent to your email</label>
                <input type="text" id="otp" name="otp" class="form-control" required maxlength="6" minlength="6">
                <div class="invalid-feedback">
                    Please provide the valid OTP.
                </div>
            </div>
            <button class="btn btn-success">Verify</button>
        </form>
    </div>
</div>