<% layout("/layouts/boilerplate.ejs") -%>
<div class="auth-container">
    <h2 class="auth-title">Edit Profile</h2>
    <form method="POST" action="/users/<%= user._id %>?_method=PUT" class="auth-form needs-validation" novalidate>
        <div class="mb-3">
            <label for="username" class="form-label">New Username</label>
            <input type="text" id="username" name="username" value="<%= user.username %>" class="form-control" required>
        </div>

        <div class="mb-3">
            <label for="email" class="form-label">New Email</label>
            <input type="email" id="email" name="email" value="<%= user.email %>" class="form-control" required>
        </div>

        <hr class="my-4" style="border-color: var(--border-color);">

        <div class="mb-3">
            <label for="password" class="form-label" style="color: #ff6b6b;">Current Password (Required)</label>
            <input type="password" id="password" name="password" placeholder="Enter password to confirm changes" class="form-control" required>
        </div>

        <div class="d-flex justify-content-between mt-4">
            <button class="auth-btn btn-primary" style="background-color: var(--primary-color);">Update Profile</button>
        </div>
    </form>
    
    <div class="text-center mt-3">
        <a href="/users/<%= user._id %>" class="text-decoration-none" style="color: var(--text-color);">Cancel</a>
    </div>
</div>
