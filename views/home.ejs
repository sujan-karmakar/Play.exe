<% layout("/layouts/boilerplate") -%>

<div class="home-container">
    <div class="games-section">
        <h2 class="section-title">All Games</h2>
        <div class="games-grid">
            <!-- Rock Paper Scissors Card -->
            <div class="game-card">
                <div class="card-content">
                    <h3>Rock Paper Scissors</h3>
                    <p>The classic hand game. Test your luck against the computer! (Leaderboard: Highest Session Score)</p>
                    <a href="/games/rockpaperscissors" class="play-btn">Play Now</a>
                    
                    <div class="mini-leaderboard">
                        <h4>Top Players</h4>
                        <ul>
                            <% if(gameLeaderboards && gameLeaderboards.rockPaperScissors) { %>
                                <% gameLeaderboards.rockPaperScissors.forEach((player, idx) => { %>
                                    <li><span>#<%= idx + 1 %> <%= player.username %></span> <span><%= player.score %></span></li>
                                <% }) %>
                            <% } %>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Simon Game Card -->
            <div class="game-card">
                <div class="card-content">
                    <h3>Simon Game</h3>
                    <p>Test your memory! Repeat the sequence of lights and sounds. (Leaderboard: Your all-time highest level)</p>
                    <a href="/games/simongame" class="play-btn">Play Now</a>

                    <div class="mini-leaderboard">
                        <h4>Top Players</h4>
                        <ul>
                            <% if(gameLeaderboards && gameLeaderboards.simonGame) { %>
                                <% gameLeaderboards.simonGame.forEach((player, idx) => { %>
                                    <li><span>#<%= idx + 1 %> <%= player.username %></span> <span><%= player.score %></span></li>
                                <% }) %>
                            <% } %>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Guessing Game Card -->
            <div class="game-card">
                <div class="card-content">
                    <h3>Guessing Game</h3>
                    <p>Can you guess the number? Challenge your intuition. (Leaderboard: Your best efficiency score)</p>
                    <a href="/games/guessinggame" class="play-btn">Play Now</a>

                    <div class="mini-leaderboard">
                        <h4>Top Players</h4>
                        <ul>
                            <% if(gameLeaderboards && gameLeaderboards.guessingGame) { %>
                                <% gameLeaderboards.guessingGame.forEach((player, idx) => { %>
                                    <li><span>#<%= idx + 1 %> <%= player.username %></span> <span><%= player.score %></span></li>
                                <% }) %>
                            <% } %>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Tic Tac Toe Card -->
            <div class="game-card">
                <div class="card-content">
                    <h3>Tic Tac Toe</h3>
                    <p>Classic strategy game. X's and O's, three in a row wins! (Leaderboard: Highest Session Score)</p>
                    <a href="/games/tictactoe" class="play-btn">Play Now</a>

                    <div class="mini-leaderboard">
                        <h4>Top Players</h4>
                        <ul>
                            <% if(gameLeaderboards && gameLeaderboards.ticTacToe) { %>
                                <% gameLeaderboards.ticTacToe.forEach((player, idx) => { %>
                                    <li><span>#<%= idx + 1 %> <%= player.username %></span> <span><%= player.score %></span></li>
                                <% }) %>
                            <% } %>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <aside class="leaderboard-sidebar">
        <div class="leaderboard-container">
            <h3>Global Leaderboard</h3>
            <% if(!currentUser) { %>
                <p style="font-size: 0.85rem; color: var(--text-color); margin-bottom: 1rem; opacity: 0.8; text-align: center;">
                    <a href="/login" style="color: var(--primary-color); text-decoration: none; font-weight: 600;">Log in</a> to save scores & join the leaderboard!
                </p>
            <% } %>
            <div class="leaderboard-list">
                <% if(leaderboardData && leaderboardData.length > 0) { %>
                    <ul class="leaderboard-items">
                        <% leaderboardData.forEach((player, index) => { %>
                            <li class="leaderboard-item <%= (currentUser && player._id.toString() === currentUser._id.toString()) ? 'highlight-user' : '' %>">
                                <span class="rank">#<%= index + 1 %></span>
                                <a href="/users/<%= player._id %>" class="username" style="text-decoration: none; color: inherit;"><%= player.username %></a>
                                <span class="score"><%= player.totalScore %></span>
                            </li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p>No scores yet!</p>
                <% } %>
            </div>
            
            <% if(currentUser && userRank) { %>
                <div class="user-rank-footer">
                    <h4>Your Position</h4>
                    <div class="user-rank-info">
                        <span class="rank">#<%= userRank.rank %></span>
                        <span class="username"><%= userRank.username %></span>
                        <span class="score"><%= userRank.totalScore %></span>
                    </div>
                </div>
            <% } %>
        </div>
    </aside>
</div>