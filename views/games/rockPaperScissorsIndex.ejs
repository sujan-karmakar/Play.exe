<% layout("/layouts/boilerplate") -%>
<% block('head').append('<link rel="stylesheet" href="/css/rockPaperScissorsStyle.css">') %>
    
    <div class="game-container">
        <h1>Rock Paper Scissors</h1>
        
        <div class="scoreboard">
            <% if(currentUser) { %>
                <p style="margin-bottom: 0.5rem; color: var(--primary-color);">Player: <%= currentUser.username %></p>
            <% } %>
            <p>Session Score</p>
            <p id="userscore">0</p>
            <% if(currentUser && currentUser.points) { %>
                <p style="font-size: 0.8em; opacity: 0.8; margin-top: 5px;">(Best: <%= currentUser.points.rockPaperScissors || 0 %>)</p>
            <% } %>
        </div>

        <div class="choices">
            <div class="choice" id="rock">
                <img src="/assets/rock.png" alt="Rock">
            </div>
            <div class="choice" id="paper">
                <img src="/assets/paper.png" alt="Paper">
            </div>
            <div class="choice" id="scissors">
                <img src="/assets/scissors.png" alt="Scissors">
            </div>
        </div>

        <div class="msgcontainer">
            <p id="msg">Choose your move!</p>
        </div>
    </div>

    <!-- Result Modal -->
    <div class="result-modal hidden" id="resultModal">
        <div class="modal-content">
            <h2 id="resultTitle">You Won!</h2>
            <div class="score-change" id="scoreChange">+1</div>
            <p id="resultMsg">Rock beats Scissors</p>
            <div class="modal-buttons">
                <button id="playAgainBtn" class="game-btn">Continue</button>
                <a href="/" class="game-btn secondary-btn" id="homeBtnModal">Home</a>
            </div>
        </div>
    </div>

    <script src="/js/rockPaperScissorsScript.js"></script>