<% layout("/layouts/boilerplate") -%>
<% block('head').append('<link rel="stylesheet" href="/css/guessingGameStyle.css">') %>
<% block('head').append('<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">') %>
    <div class="game-container">
        <h1>Guess The Number</h1>
        <% if(currentUser) { %>
            <p style="margin-bottom: 0.5rem; color: var(--primary-color);">Player: <%= currentUser.username %></p>
            <p>Highest Score: <span id="current-score"><%= (currentUser.points && currentUser.points.guessingGame) || 0 %></span></p>
        <% } %>
        
        <!-- Setup Section -->
        <div id="setup-area">
            <p class="subtitle">Enter the maximum number for the range</p>
            <div class="game-content">
                <div class="input-group">
                    <input type="number" id="maxRangeInput" class="game-input" placeholder="Max Range (e.g. 100)" min="2">
                </div>
                <button id="setRangeBtn" class="game-btn">Start Game</button>
            </div>
        </div>

        <!-- Game Section -->
        <div id="play-area" class="hidden">
            <p class="subtitle" id="rangeText">Pick a number between 1 and 100</p>
            
            <div class="game-content">
                <div class="input-group">
                    <input type="number" id="guessInput" class="game-input" placeholder="Enter your guess" min="1">
                </div>
                <button id="submitBtn" class="game-btn">Guess</button>
            </div>

            <div class="message-area">
                <p id="message">Good luck!</p>
                <p id="attempts">Attempts: 0</p>
            </div>

            <button id="restartBtn" class="game-btn hidden">Play Again</button>
        </div>
    </div>

    <script src="/js/guessingGameScript.js"></script>